{
  "manifest_version": 3,
  "name": "Form Memory Assistant",
  "version": "1.0.0",
  "description": "Remember form values and suggest them on similar fields.",
  "permissions": ["storage", "activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Form Memory Assistant",
    "default_popup": "popup.html"
  }
}
